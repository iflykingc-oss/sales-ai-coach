{
  "version": 2,
  "installCommand": "corepack enable && pnpm install",
  "buildCommand": "cd packages/web && pnpm run build",
  "outputDirectory": "packages/web/dist",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "3 0 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "7 2 * * 0"
    },
    {
      "path": "/api/cron/knowledge",
      "schedule": "15 3 * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "api/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/((?!api/|health|assets/|favicon|robots|manifest).*)", "destination": "/index.html" }
  ]
}

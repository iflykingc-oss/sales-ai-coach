# AI Service Configuration
# Copy this file to .env and fill in your API keys

# Server
DEBUG=false

# AI Model API Keys (at least one is required)
# Qwen (йШњйЗМйАЪдєЙеНГйЧЃ) - Default model
QWEN_API_KEY=your_qwen_api_key_here

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# Model Configuration
# Options: qwen, openai, anthropic, minimax
DEFAULT_MODEL=qwen
FALLBACK_MODELS=["openai", "anthropic"]

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
REQUESTS_PER_MINUTE=60

# CORS Origins
CORS_ORIGINS=["http://localhost:5173", "https://www.aisalecoach.work"]

# IM Integration (й£Юдє¶/йТЙйТЙ)
# й£Юдє¶еЉАжФЊеє≥еП? https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# йТЙйТЙеЉАжФЊеє≥еП? https://open.dingtalk.com
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# Feature Flags
USE_LANGGRAPH_COACHING=false

# Inbound auth: shared secret the upstream API service passes via x-api-key.
# REQUIRED in production. Generate with: openssl rand -hex 32
# Must match AI_SERVICE_API_KEY in packages/api/.env
AI_SERVICE_API_KEY=

# Allow unencrypted Feishu events (debug only). Leave false in production.
FEISHU_ALLOW_UNENCRYPTED=false
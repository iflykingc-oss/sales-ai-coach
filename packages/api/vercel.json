{
  "version": 2,
  "installCommand": "corepack enable && pnpm install",
  "buildCommand": "npx prisma generate --schema=./src/prisma/schema.prisma",
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/api" }
  ]
}

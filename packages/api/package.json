{
  "name": "@sales-ai-coach/api",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "./src/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate --schema=./src/prisma/schema.prisma && tsc --build",
    "vercel-build": "npx prisma generate --schema=./src/prisma/schema.prisma",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "@sales-ai-coach/shared": "workspace:*",
    "@sentry/node": "^10.57.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.2.0",
    "stripe": "^22.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "pg": "^8.21.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

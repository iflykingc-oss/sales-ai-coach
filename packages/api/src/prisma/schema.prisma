generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TEAM_OWNER
}

enum Plan {
  FREE
  PROFESSIONAL
  TEAM
  ENTERPRISE
}

enum SessionStatus {
  PENDING
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum PipelineStage {
  SCRIPT
  PRACTICE
  REVIEW
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum InputType {
  TEXT
  IMAGE
  VOICE
  FORM
  PASTE
}

enum ScriptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KnowledgeStatus {
  ACTIVE
  ARCHIVED
  REVIEW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  plan      Plan      @default(FREE)
  industry  String[]
  teamId    String?
  team      Team?     @relation(fields: [teamId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  scripts         Script[]
  knowledge       KnowledgeItem[]
  practices       PracticeSession[]
  reviews         ReviewReport[]
  scriptFeedbacks ScriptFeedback[]
  usageLogs       UsageLog[]
  sharedScripts   SharedScript[]
  assignedTasks   TeamTask[]

  @@map("users")
}

model Team {
  id          String    @id @default(uuid())
  name        String
  ownerId     String    @unique @map("owner_id")
  plan        Plan      @default(TEAM)
  memberCount Int       @default(1) @map("member_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members       User[]
  tasks         TeamTask[]
  sharedScripts SharedScript[]

  @@map("teams")
}

model Session {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?       @map("team_id")
  name      String
  industry  String?
  status    SessionStatus @default(PENDING)
  stage     PipelineStage @default(SCRIPT)
  tags      String[]
  customerName String?    @map("customer_name")
  customerInfo Json?      @map("customer_info")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  messages  Message[]
  scripts   Script[]
  practices PracticeSession[]
  reviews   ReviewReport[]

  @@index([userId])
  @@index([teamId])
  @@index([stage])
  @@map("sessions")
}

model Message {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  inputType InputType   @default(TEXT) @map("input_type")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("messages")
}

model Script {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?      @map("session_id")
  session   Session?     @relation(fields: [sessionId], references: [id])
  content   String       @db.Text
  style     String
  tags      String[]
  industry  String?
  status    ScriptStatus @default(DRAFT)
  weight    Float        @default(1.0)
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([sessionId])
  @@map("scripts")
}

model KnowledgeItem {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?         @map("team_id")
  source    String
  content   String          @db.Text
  tags      String[]
  industry  String?
  weight    Float           @default(1.0)
  status    KnowledgeStatus @default(ACTIVE)
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([teamId])
  @@map("knowledge_items")
}

model PracticeSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?   @map("session_id")
  session   Session?  @relation(fields: [sessionId], references: [id])
  scriptId  String?   @map("script_id")
  scenario  String
  industry  String?
  rounds    Int
  score     Float
  feedback  Json
  transcript Json?
  createdAt DateTime  @default(now()) @map("created_at")

  reviewReport ReviewReport?

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("practice_sessions")
}

model ReviewReport {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId         String?  @map("session_id")
  session           Session? @relation(fields: [sessionId], references: [id])
  practiceSessionId String?  @unique @map("practice_session_id")
  practiceSession   PracticeSession? @relation(fields: [practiceSessionId], references: [id])
  summary           String   @db.Text
  strengths         String[]
  improvements      String[]
  recommendations   String[]
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([sessionId])
  @@index([practiceSessionId])
  @@map("review_reports")
}

model IndustryPlugin {
  id               String   @id @default(uuid())
  name             String
  industry         String   @unique
  category         String?
  description      String?  @db.Text
  version          String   @default("1.0.0")
  rating           Float    @default(0)
  installCount     Int      @default(0) @map("install_count")
  scripts          Json     @default("[]")
  scenarios        Json     @default("[]")
  knowledge        Json     @default("[]")
  customerProfiles Json     @default("[]") @map("customer_profiles")
  bestPractices    Json     @default("[]") @map("best_practices")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("industry_plugins")
}

model SharedScript {
  id         String   @id @default(uuid())
  teamId     String   @map("team_id")
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation(fields: [authorId], references: [id])
  scriptId   String?  @map("script_id")
  title      String
  content    String   @db.Text
  industry   String?
  tags       String[]
  likes      Int      @default(0)
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  likedBy SharedScriptLike[]

  @@index([teamId])
  @@index([authorId])
  @@map("shared_scripts")
}

model SharedScriptLike {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  scriptId   String       @map("script_id")
  script     SharedScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([scriptId])
  @@unique([userId, scriptId])
  @@map("shared_script_likes")
}

model ScriptFeedback {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scriptId  String   @map("script_id")
  type      String
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scriptId])
  @@index([userId])
  @@map("script_feedbacks")
}

model ModelConfig {
  id           String   @id @default(uuid())
  provider     String
  modelId      String   @map("model_id")
  displayName  String   @map("display_name")
  apiKey       String?  @map("api_key")
  baseUrl      String?  @map("base_url")
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(2048) @map("max_tokens")
  isActive     Boolean  @default(true) @map("is_active")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([provider, modelId])
  @@map("model_configs")
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  count     Int      @default(1)
  date      String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, action, date])
  @@index([userId, date])
  @@map("usage_logs")
}

model TeamTask {
  id         String     @id @default(uuid())
  teamId     String     @map("team_id")
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assigneeId String     @map("assignee_id")
  assignee   User?      @relation(fields: [assigneeId], references: [id])
  type       String
  scenario   String
  deadline   DateTime
  status     TaskStatus @default(PENDING)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([teamId, deadline])
  @@index([assigneeId])
  @@map("team_tasks")
}

{
  "version": 2,
  "builds": [
    {
      "src": "packages/api/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/api/src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NODE_OPTIONS": "--no-warnings"
  }
}

{
  "name": "sales-ai-coach",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter api prisma generate",
    "db:push": "pnpm --filter api prisma db push",
    "db:studio": "pnpm --filter api prisma studio",
    "ai:dev": "cd packages/ai-service && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:e2e": "node e2e-test.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.60.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.57.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  }
}

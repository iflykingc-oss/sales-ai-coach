# Sales AI Coach - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://sales_ai:sales_ai_secret@localhost:5432/sales_ai_coach

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dev-secret-change-in-production

# API Service URLs
AI_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# AI Model API Keys
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
QWEN_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Server
PORT=3001
NODE_ENV=development
